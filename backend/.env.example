PORT=5000
NODE_ENV=development

# Database
DATABASE_URL="postgresql://user:password@localhost:5432/sabzi_waala"

# JWT
JWT_SECRET=your_jwt_secret_key_here_change_in_production
JWT_EXPIRE=7d

# Razorpay
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_SECRET_KEY=your_razorpay_secret_key

# Firebase
FIREBASE_API_KEY=your_firebase_api_key
FIREBASE_AUTH_DOMAIN=your_firebase_auth_domain
FIREBASE_PROJECT_ID=your_firebase_project_id

# WhatsApp
WHATSAPP_API_URL=https://api.whatsapp.com
WHATSAPP_BEARER_TOKEN=your_whatsapp_token

# Email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_email_password
SMTP_FROM=noreply@sabziwaala.com

# AWS/Storage
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1
AWS_BUCKET_NAME=sabzi-waala-images

# Redis
REDIS_URL=redis://localhost:6379

# Google Maps (for delivery tracking)
GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# Admin Panel
ADMIN_EMAIL=admin@sabziwaala.com

# Payment
PAYMENT_GATEWAY=razorpay

# Delivery
DEFAULT_DELIVERY_TIME=30
DEFAULT_DELIVERY_FEE=30
FREE_DELIVERY_THRESHOLD=500
